{
  "name": "repo-analyzer-green",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": "24.x",
    "pnpm": "10.29.3"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "type-escape:check": "node scripts/check-type-escapes.ts",
    "barrel-files:check": "node scripts/check-barrel-files.ts",
    "commit-message:check": "node scripts/check-commit-message.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "rm -rf .next/types .next/dev/types && next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:red-parity": "RED_UI_PARITY=1 playwright test e2e/red-ui-parity.spec.ts",
    "check": "pnpm run type-escape:check && pnpm run barrel-files:check && pnpm lint && pnpm format:check && pnpm typecheck && pnpm test",
    "ci": "pnpm check && pnpm build && pnpm test:e2e"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.0",
    "lucide-react": "^1.11.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "tar": "^7.5.13",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.6",
    "oxlint": "^1.30.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
